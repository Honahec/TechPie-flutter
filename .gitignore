# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Development related
.idea/
.vscode/
.claude/

# Environment files
.envrc
# Local Xcode overrides
macos/Runner/Configs/Local.xcconfig

# OHOS signing artifacts
ohos/signature/*.p12
ohos/signature/*.csr
ohos/signature/*.pem
ohos/signature/*.p7b
ohos/signature/*.cer

# OHOS build profile is generated from build-profile.template.json5 + OHOS_* env
# vars on every hvigor run; never commit the rendered file (it contains secrets).
ohos/build-profile.json5

# Generated files
.flutter-plugins

# Android: Groovy build scripts re-generated alongside the Kotlin DSL
# (.kts) versions we actually use. Keep only the .kts variants.
/android/build.gradle
/android/settings.gradle
/android/app/build.gradle